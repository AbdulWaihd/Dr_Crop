# =============================================================================
# Dr. Crop — backend secrets (copy this file to .env and fill in values)
# Copy:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# Never commit .env — it is gitignored.
# =============================================================================

# --- Required for /predict (vision + synthesis) and smart /recommend ----------
# Gemini (AIza…), OpenAI (sk-…), or Mistral (set LLM_BASE_URL to api.mistral.ai/v1).
LLM_API_KEY=
# OPENAI_API_KEY=

# OpenAI: https://api.openai.com/v1 — Mistral: https://api.mistral.ai/v1 — ignored for Gemini keys.
LLM_BASE_URL=https://api.openai.com/v1

# Examples: gpt-4o-mini, mistral-small-latest, gemini-2.0-flash
LLM_MODEL=gpt-4o-mini

# Vision-capable id for your provider (e.g. pixtral-12b-latest, gpt-4o-mini, gemini-2.0-flash)
VISION_MODEL=gpt-4o-mini

# --- Optional: OpenWeatherMap (legacy demo helpers in app/services/weather_service.py) ---
OPENWEATHERMAP_API_KEY=

# --- Optional: web search RAG (better diagnosis context + treatment research) ---
EXA_API_KEY=

# --- Optional: Apify integration (see app/services/apify_service.py) ---------
APIFY_API_KEY=
